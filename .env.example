# Copy this to .env and fill in your values
# cp .env.example .env

# Your domain pointing to the Hostinger VPS IP
USE_DOMAIN=use.yourcompany.com

# Internal port Flask runs on (no need to change this)
USE_SERVER_PORT=7186

# Redis broker URL (no need to change this for Docker Compose)
CELERY_BROKER_URL=redis://broker:6379/0
